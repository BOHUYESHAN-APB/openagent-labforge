{
  "name": "openagent-labforge",
  "version": "0.1.0",
  "description": "Lightweight OpenCode plugin with bioinformatics support, based on opencode-workspace",
  "main": "./dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "openagent-labforge": "bin/openagent-labforge.js"
  },
  "files": [
    "dist",
    "bin",
    "generated"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm --external @ast-grep/napi && tsc --emitDeclarationOnly",
    "clean": "rm -rf dist",
    "prepare": "bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "keywords": [
    "opencode",
    "plugin",
    "bioinformatics",
    "agent",
    "orchestration"
  ],
  "author": "OpenAgent LabForge Contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/BOHUYESHAN-APB/openagent-labforge.git"
  },
  "bugs": {
    "url": "https://github.com/BOHUYESHAN-APB/openagent-labforge/issues"
  },
  "homepage": "https://github.com/BOHUYESHAN-APB/openagent-labforge#readme",
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.14.29",
    "@opencode-ai/sdk": "^1.14.29",
    "detect-terminal": "^1.0.0",
    "jsonc-parser": "^3.2.0",
    "node-notifier": "^10.0.0",
    "unique-names-generator": "^4.7.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node-notifier": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
