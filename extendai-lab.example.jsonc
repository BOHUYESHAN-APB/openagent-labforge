{
  // ========== 默认 agent / 可见顺序 ==========
  // 真正的默认 agent（当 OpenCode 配置里未显式设置 default_agent 时生效）
  "defaultAgentName": "engineer",

  // 只影响主专家在 UI 中的顺序/突出程度，不改变 default_agent
  // 例如保持工程主线为默认 agent，但让 bio-analyst 更靠前显示
  // "preferredVisibleAgent": "bio-analyst",

  // ========== 模型配置 ==========
  "model_preferences": {
    // 启用自定义模型配置
    "enabled": true,

    // 预设配置文件：openai | deepseek | mixed
    // openai: 全部使用 OpenAI 模型（GPT-5.5/5.4/5.4-mini）
    // deepseek: 全部使用 DeepSeek 模型（deepseek-chat）
    // mixed: 混合使用（规划用 GPT，执行用 DeepSeek）
    "profile": "mixed"

    // 或者手动配置每个 agent 的模型（支持 fallback 数组）
    // "perAgent": {
    //   "orchestrator": ["openai/gpt-5.5", "deepseek/deepseek-chat"],
    //   "deep-worker": ["deepseek/deepseek-chat", "openai/gpt-5.4"]
    // }
  },

  // ========== 子代理成本策略 ==========
  "subagentPolicy": {
    // 完整 Slash 命令：/ol-subagents-M, /ol-subagents-F,
    // /ol-subagents-C, /ol-subagents-MO。
    // M=minimal, F=full, C=custom, MO=main-only。
    // OpenCode UI 目前通常只补全命令名，不补全后续参数；所以参数型选择
    // 优先注册成完整命令，而不是只依赖 argumentHint/description。
    // 注意：subagent 注册变化需要修改 config 后 reload/restart 插件。
    // minimal: 默认低子代理/缓存优先模式，只保留 explorer/librarian/oracle/fixer，
    //          observer 仅在从 disabled_agents 移除后启用
    // full: 完整启用已配置子代理，适合平台包月/按调用计费或强前缀缓存服务商
    // custom: 只启用 allowedAgents 中列出的可委托子代理
    // main-only: 禁用内置可委托子代理，把专家提示当作主代理本地 checklist
    // 并行子代理仍会被提示使用同一段 shared-prefix snapshot，以提高 DeepSeek
    // 等前缀缓存服务商的缓存命中率；如安装 shared-context MCP，也会优先复用共享 session。
    "mode": "minimal"
    // "allowedAgents": ["explorer", "librarian", "oracle", "fixer"]
  },

  // ========== 提示词模式配置 ==========
  "prompt_mode": {
    // 默认模式：heavy | light | turbo
    // heavy: Omo 风格，542 行，Phase 0-3 工作流，失败恢复
    // light: OMOS 风格，200-300 行，详细委托规则，并行执行（默认）
    // turbo: OLD-2 风格，58 行，"KEEP GOING" 哲学，快速执行
    "defaultMode": "light",

    // 是否允许运行时切换模式（通过 /ol-light, /ol-heavy, /ol-turbo 命令）
    "allowModeSwitch": true,

    // 应用模式的 agent 列表（默认：所有主 agent）
    "applyToAgents": [
      "orchestrator",
      "bio-orchestrator",
      "deep-worker",
      "prometheus",
      "atlas"
    ]
  },

  // ========== Bio Skills 配置 ==========
  "bioSkills": {
    // 是否启用 bio skills
    "enabled": true,

    // bioSkills 仓库路径（可选，默认插件包内 resources/bioSkills）
    // "repoPath": "~/bioSkills",

    // 允许使用 bio skills 的 agent（* 表示所有 agent）
    "allowedAgents": ["*"]
  },

  // ========== MCP 配置 ==========
  // 禁用特定 MCP（默认启用：context7, grep_app, websearch, semantic_scholar_fastmcp）
  "disabled_mcps": [
    // 扩展 MCP（默认禁用，按需启用）
    "arxiv_mcp",
    "browser_puppeteer",
    "chrome_devtools_mcp",
    "deepwiki_mcp",
    "open_websearch_mcp",
    "paper_search_mcp"
  ],

  // ========== Agent 配置 ==========
  // 禁用特定 agent
  "disabled_agents": [
    "observer" // 默认禁用 observer
  ],

  // ========== Multiplexer 配置 ==========
  "multiplexer": {
    "type": "auto", // auto | tmux | zellij | none
    "layout": "main-vertical",
    "main_pane_size": 60
  },

  // ========== Council 配置 ==========
  "council": {
    "councillor_execution_mode": "parallel",
    "timeout": 180000,
    "presets": {
      "default": {
        "analyst": { "model": "openai/gpt-5.4-mini" },
        "critic": { "model": "anthropic/claude-opus-4" }
      }
    }
  },

  // ========== Checkpoint 配置 ==========
  "checkpoint": {
    "enabled": true,
    "auto_trigger": false // 是否自动触发 checkpoint（基于上下文压力）
  },

  // ========== Compression 配置 ==========
  "compression": {
    "enabled": false, // 全局开关（默认禁用）
    "strategy": "auto", // auto | manual | hybrid
    "thresholdTokens": 100000,

    // L1/L2/L3 比例阈值永远基于 OpenCode 实际上报的当前 provider/model
    // context limit 计算，不要按模型家族名去猜。
    // 例如同样是 GPT-5.5，在不同 provider / 账号方案下 context limit 可能不同。
    "profiles": {
      "engineering": {
        "l1": 0.5,
        "l2": 0.65,
        "l3": 0.8
      },
      "bio": {
        "l1": 0.55,
        "l2": 0.7,
        "l3": 0.85
      }
    }
  }
}
