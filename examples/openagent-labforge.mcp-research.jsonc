{
  "$schema": "../assets/openagent-labforge.schema.json",

  // Research-oriented MCP policy (safe defaults)
  "mcp_policy": {
    "network_profile": "auto",
    "bing_cn_english_fallback": true,
    // Built-in MCPs (5) are enabled by default:
    // websearch, context7, grep_app, browser_puppeteer, paper_search_mcp
    // Use `enable` / `disable` only when you want an override.
    // Example (turn one off):
    // "disable": ["browser_puppeteer"]
  },

  // Manual hard-disable still wins when needed
  "disabled_mcps": []
}
