{
  "$schema": "../assets/openagent-labforge.schema.json",

  // Research-oriented MCP policy (safe defaults)
  "mcp_policy": {
    "network_profile": "auto",
    "search_english_fallback": true,
    "enable": [
      "arxiv_mcp",
      "fetch_browser",
      "browser_puppeteer",
      "deepwiki_mcp",
      "open_websearch_mcp"
    ],
    "disable": ["semantic_scholar_fastmcp"]
  },

  // Manual hard-disable still wins when needed
  "disabled_mcps": []
}
