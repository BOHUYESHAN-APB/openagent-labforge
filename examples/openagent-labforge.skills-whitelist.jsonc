{
  "$schema": "../assets/openagent-labforge.schema.json",

  // Load only reviewed and allowlisted skills generated by `bun run skills:sync`
  "skills": {
    "sources": [
      { "path": "./external/skills-whitelist", "recursive": true }
    ],

    // Example: optional explicit runtime gating for specific skill names
    "disable": [
      // "some-high-risk-skill"
    ]
  }
}
